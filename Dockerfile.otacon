# Stage 1: Build scrcpy
FROM debian:trixie-slim AS scrcpy-builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    meson \
    ninja-build \
    pkg-config \
    git \
    libavcodec-dev \
    libavdevice-dev \
    libavformat-dev \
    libavutil-dev \
    libswresample-dev \
    libusb-1.0-0-dev \
    libsdl2-dev \
    android-sdk-platform-tools \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

ARG SCRCPY_VERSION=3.3.4

ADD https://github.com/Genymobile/scrcpy/releases/download/v${SCRCPY_VERSION}/scrcpy-server-v${SCRCPY_VERSION} /opt/scrcpy-server.jar

RUN git clone --depth 1 --branch v${SCRCPY_VERSION} https://github.com/Genymobile/scrcpy.git /src/scrcpy
WORKDIR /src/scrcpy
RUN meson setup builddir --buildtype=release -Dprebuilt_server=/opt/scrcpy-server.jar \
    && ninja -C builddir \
    && ninja -C builddir install

# Stage 2: Build audio server
FROM rust:1-slim-bookworm AS audio-builder

WORKDIR /src/server
COPY src/server/Cargo.toml src/server/Cargo.lock* ./
COPY src/server/src/ ./src/
COPY src/server/static/ ./static/
RUN cargo build --release

# Stage 3: Runtime
FROM debian:trixie-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    # Phone mirror
    tigervnc-standalone-server \
    tigervnc-tools \
    adb \
    libsdl2-2.0-0 \
    libavcodec61 \
    libavdevice61 \
    libavformat61 \
    libavutil59 \
    libswresample5 \
    libusb-1.0-0 \
    supervisor \
    bc \
    x11-xserver-utils \
    # WiFi AP
    hostapd \
    dnsmasq \
    iptables \
    iproute2 \
    # Audio
    alsa-utils \
    lame \
    # Bluetooth audio (HFP HF via BlueALSA)
    bluez \
    dbus \
    bluez-alsa-utils \
    rfkill \
    procps \
    python3-dbus \
    python3-gi \
    && rm -rf /var/lib/apt/lists/*

# scrcpy
COPY --from=scrcpy-builder /usr/local/bin/scrcpy /usr/local/bin/scrcpy
COPY --from=scrcpy-builder /usr/local/share/scrcpy/ /usr/local/share/scrcpy/

# Audio server
COPY --from=audio-builder /src/server/target/release/otacon-server /usr/local/bin/otacon-server

ENV PATH="/usr/lib/android-sdk/platform-tools:${PATH}"
ENV DISPLAY_NUM=50
ENV DISPLAY_RESOLUTION=540x1204
ENV SCRCPY_MAX_FPS=15
ENV SCRCPY_BITRATE=2M
ENV SCRCPY_MAX_SIZE=1204
ENV VNC_PORT=5900
ENV VNC_PASSWORD=
ENV WIFI_AP_SSID=
ENV WIFI_AP_PASSWORD=
ENV AUDIO_PORT=8080
ENV ALSA_CAPTURE_DEVICE=plughw:Device,0
ENV ALSA_PLAYBACK_DEVICE=plughw:Device,0
ENV AUDIO_BACKEND=alsa

COPY config/supervisord-base.conf /etc/supervisor/conf.d/supervisord-base.conf
COPY config/supervisord-bluetooth.conf /etc/supervisor/conf.d/supervisord-bluetooth.conf
COPY config/bluetooth-main.conf /etc/bluetooth/main.conf
COPY scripts/bluetooth-agent.py /opt/bluetooth-agent.py
COPY scripts/bluetooth-pair.sh /opt/bluetooth-pair.sh
COPY scripts/bluetooth-connect.sh /opt/bluetooth-connect.sh
COPY scripts/bluetooth-status.sh /opt/bluetooth-status.sh
COPY scripts/otacon-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh /opt/bluetooth-pair.sh /opt/bluetooth-agent.py \
    /opt/bluetooth-status.sh /opt/bluetooth-connect.sh

RUN mkdir -p /run/dbus /etc/hostapd

EXPOSE 5900 8080

ENTRYPOINT ["/entrypoint.sh"]
