# Deploy
PI_HOST=otacon-pi
PI_USER=nick
OTACON_REPO=otacon-dev

# Secrets
VNC_PASSWORD=
TS_AUTH_KEY=

# Tailscale (optional, default: system hostname)
TS_HOSTNAME=otacon-pi

# Display
DISPLAY_NUM=50
DISPLAY_RESOLUTION=540x1204
SCRCPY_MAX_FPS=15
SCRCPY_BITRATE=2M
SCRCPY_MAX_SIZE=1204

# VNC
VNC_PORT=5900

# WiFi AP (Pi creates access point for phone — bypasses network proxy)
WIFI_AP_SSID=OtaconAP
WIFI_AP_PASSWORD=

# Audio
AUDIO_PORT=8080
AUDIO_BACKEND=alsa
ALSA_CAPTURE_DEVICE=plughw:Device,0
ALSA_PLAYBACK_DEVICE=plughw:Device,0
# Bluetooth audio profile: sco = calls (HFP, 16kHz), a2dp = media (A2DP, resampled to 16kHz)
# BLUEALSA_DEVICE=bluealsa:DEV=00:00:00:00:00:00,PROFILE=sco

# Watchtower (auto-update)
WATCHTOWER_POLL_INTERVAL=300
