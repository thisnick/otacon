# Deploy
PI_HOST=otacon-pi
PI_USER=nick
OTACON_REPO=otacon-dev

# Secrets
VNC_PASSWORD=
TS_AUTH_KEY=

# Tailscale (optional, default: system hostname)
TS_HOSTNAME=otacon-pi

# Display
DISPLAY_NUM=50
DISPLAY_RESOLUTION=540x1204
SCRCPY_MAX_FPS=15
SCRCPY_BITRATE=2M
SCRCPY_MAX_SIZE=1204

# VNC
VNC_PORT=5900

# Gnirehtet
GNIREHTET_DNS=8.8.8.8,8.8.4.4

# Audio
AUDIO_PORT=8080
ALSA_CAPTURE_DEVICE=plughw:Device,0
ALSA_PLAYBACK_DEVICE=plughw:Device,0

# Watchtower (auto-update)
WATCHTOWER_POLL_INTERVAL=300
